# =============================================================================
# ATELIER BIANCO — modèle d’environnement (VERSIONNÉ, sans secrets)
# -----------------------------------------------------------------------------
# 1. Copier vers .env.local à la racine du projet :
#    cp .env.example .env.local     (macOS / Linux)
#    copy .env.example .env.local   (Windows cmd)
#    Copy-Item .env.example .env.local   (PowerShell)
# 2. Remplir .env.local avec vos vraies clés (Supabase → Settings → API, etc.).
# 3. Ne jamais committer .env.local ni .env contenant des secrets.
#
# Ordre Next.js : .env.local surcharge .env — utilisez UN SEUL fichier secret : .env.local
# =============================================================================

# --- Application (URLs canoniques : auth callback, Stripe return, emails) -----
# En local : http://localhost:3000  |  En prod : https://votre-domaine.com
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (obligatoire : catalogue, auth, admin) --------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# UNE des deux clés publiques (publishable recommandée sur les projets récents) :
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serveur uniquement (API checkout, catalogue serveur, webhooks) — jamais NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (checkout + webhooks) --------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# --- Optionnel ----------------------------------------------------------------
# NEXT_PUBLIC_HIDE_GOOGLE_OAUTH=true
# NEXT_PUBLIC_ADMIN_BOOTSTRAP_EMAIL=admin@votre-domaine.com
# NEXT_PUBLIC_DEV_SKIP_STRIPE=true
# NEXT_PUBLIC_SHOW_CATALOG_MOCK=true
# NEXT_PUBLIC_CATALOG_DEV_FALLBACK=true
# DISABLE_HMR=true
